    "print(\"  model_id = 'ollama/llama3.2'\")\n",
    "print(\"  Requires: Ollama installed + model pulled (`ollama pull llama3.2`)\")\n",
    "print(\"  OK for: IRB-protected transcripts, identifiable health information\")\n",
